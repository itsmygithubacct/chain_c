  public function slashValidator(Sha256 validatedRicardianHash, PubKey validatedAgent, int attAmount, int attLimit, Sha256 attReceiptHash, RabinSig fraudSig, PubKey reporter, SigHashPreimage __scrypt_ts_txPreimage, int __scrypt_ts_changeAmount, Ripemd160 __scrypt_ts_changeAddress) {
    require(Tx.checkPreimageSigHashType(__scrypt_ts_txPreimage, SigHashType(b'41')));
