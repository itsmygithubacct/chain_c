  public function executeAction(Sig agentSig, Sig counterpartySig, PubKey counterparty, int amount, Sha256 actionHash, Sha256 provenanceHash, int attestedLimit, RabinSig validatorSig, SigHashPreimage __scrypt_ts_txPreimage, int __scrypt_ts_changeAmount, Ripemd160 __scrypt_ts_changeAddress, bytes __scrypt_ts_prevouts) {
